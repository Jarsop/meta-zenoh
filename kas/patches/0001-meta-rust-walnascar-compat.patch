     config.set("build", "profiler", e(True))
 
-    cargo = d.expand("${WORKDIR}/rust-snapshot/bin/cargo")
+    cargo = d.expand("${UNPACKDIR}/rust-snapshot/bin/cargo")
     config.set("build", "cargo", e(cargo))
 
