diff --git a/recipes-devtools/rust/rust.inc b/recipes-devtools/rust/rust.inc
index 6cd31af..e60ee4f 100644
--- a/recipes-devtools/rust/rust.inc
+++ b/recipes-devtools/rust/rust.inc
@@ -43,25 +43,25 @@ setup_cargo_environment () {
 include rust-common.inc
 
 do_rust_setup_snapshot () {
-    for installer in "${WORKDIR}/rust-snapshot-components/"*"/install.sh"; do
-        "${installer}" --prefix="${WORKDIR}/rust-snapshot" --disable-ldconfig
+    for installer in "${UNPACKDIR}/rust-snapshot-components/"*"/install.sh"; do
+        "${installer}" --prefix="${UNPACKDIR}/rust-snapshot" --disable-ldconfig
     done
 
     # Some versions of rust (e.g. 1.18.0) tries to find cargo in stage0/bin/cargo
